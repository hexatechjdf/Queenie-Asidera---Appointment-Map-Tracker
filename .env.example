# Auth mode. true = always get the token from the parent window (GHL iframe) and
# ignore the hardcoded dev token/location. false/unset = use the hardcoded dev
# token below for local development.
VITE_PRODUCTION=false

# GoHighLevel API
VITE_GHL_API_BASE=https://services.leadconnectorhq.com/

# Dev-only hardcoded GHL token (used only when VITE_PRODUCTION is not true).
# Do NOT commit a real token. Leave blank in .env.example.
VITE_GHL_DEV_TOKEN=
VITE_GHL_LOCATION_ID=

# Google Maps / Places API key (used for geocoding + location autocomplete only,
# not for rendering the map — the map uses Leaflet + OpenStreetMap tiles).
VITE_GOOGLE_MAPS_API_KEY=

# Rep configuration endpoint (Google Apps Script web app) that returns the
# allowed sales reps + marker colors per location as JSON. Optional — defaults to
# the deployed script when unset. No API key or sheet id required.
VITE_REP_CONFIG_URL=
